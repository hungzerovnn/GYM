{
  "manifest_version": 3,
  "name": "FitFlow Social Link Bridge",
  "description": "Auto-link CRM browser sessions, sync Messenger sidebar, and send heartbeat from the active browser profile.",
    "version": "0.4.0",
  "permissions": ["storage", "tabs", "activeTab", "scripting"],
  "host_permissions": ["http://localhost/*", "http://127.0.0.1/*", "https://*/*"],
    "action": {
        "default_title": "FitFlow Social Link Bridge",
        "default_popup": "popup.html"
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "http://localhost/*",
                "http://127.0.0.1/*",
                "https://www.messenger.com/*",
                "https://messenger.com/*",
                "https://www.facebook.com/*",
        "https://facebook.com/*"
      ],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ]
}
