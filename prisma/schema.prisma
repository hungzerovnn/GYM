model StaffShift {
  id                         String   @id @default(cuid())
  branchId                   String
  code                       String
  name                       String
  startTime                  String
  endTime                    String
  breakMinutes               Int      @default(0)
  workHours                  Float?
  lateToleranceMinutes       Int      @default(0)
  earlyLeaveToleranceMinutes Int      @default(0)
  overtimeAfterMinutes       Int      @default(0)
  mealAllowance              Float    @default(0)
  nightAllowance             Float    @default(0)
  isOvernight                Boolean  @default(false)
  note                       String?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
