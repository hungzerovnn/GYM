  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  deletedAt     DateTime?
  branch        Branch              @relation(fields: [branchId], references: [id], onDelete: Restrict)
  supplier      Supplier            @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  items         PurchaseOrderItem[]

  @@unique([branchId, code])
  @@index([branchId, status])
  @@index([deletedAt])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  productId       String
  quantity        Int
  unitPrice       Decimal       @default(0) @db.Decimal(14, 2)
  totalPrice      Decimal       @default(0) @db.Decimal(14, 2)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product         Product       @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([purchaseOrderId])
  @@index([productId])
  @@map("purchase_order_items")
}

model AttendanceMachine {
  id               String   @id @default(cuid())
  branchId         String
  code             String   @unique
  name             String
  vendor           AttendanceMachineVendor   @default(GENERIC)
  machineType      AttendanceMachineType     @default(FINGERPRINT)
  protocol         AttendanceMachineProtocol @default(GENERIC_EXPORT)
  model            String?
  deviceIdentifier String?
  commKey          String?
  connectionPort   String?
  host             String?
  username         String?
  password         String?
  apiKey           String?
  webhookSecret    String?
  timeZone         String   @default("Asia/Bangkok")
  pollingIntervalSeconds Int @default(300)
  supportsFaceImage Boolean @default(false)
  supportsFaceTemplate Boolean @default(false)
  supportsCardEnrollment Boolean @default(false)
  supportsFingerprintTemplate Boolean @default(false)
  supportsWebhook  Boolean  @default(false)
  syncEnabled      Boolean  @default(true)
  connectionStatus String   @default("DISCONNECTED")
  lastSyncedAt     DateTime?
  lastHeartbeatAt  DateTime?
  lastErrorCode    String?
  lastErrorMessage String?
  lastLogCursor    String?
  lastUserSyncCursor String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  branch           Branch   @relation(fields: [branchId], references: [id], onDelete: Restrict)
  personMappings   AttendanceMachinePersonMap[]
  attendanceEnrollments AttendanceEnrollment[]
  biometricAssets  AttendanceBiometricAsset[]
  staffAttendanceEvents StaffAttendanceEvent[]
  memberPresenceSessions MemberPresenceSession[]

  @@index([branchId, connectionStatus])
  @@map("attendance_machines")
}

model AttendanceMachinePersonMap {
  id                 String               @id @default(cuid())
  branchId           String
  attendanceMachineId String
  personType         AttendancePersonType
  personId           String
  appAttendanceCode  String?
  machineUserId      String?
  machineCode        String?
  cardCode           String?
  faceProfileId      String?
  fingerprintProfileId String?
  syncStatus         AttendanceSyncStatus @default(PENDING)
  lastSyncedAt       DateTime?
  lastError          String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  branch             Branch               @relation(fields: [branchId], references: [id], onDelete: Restrict)
  attendanceMachine  AttendanceMachine    @relation(fields: [attendanceMachineId], references: [id], onDelete: Cascade)
  attendanceEnrollments AttendanceEnrollment[]

  @@unique([attendanceMachineId, personType, personId])
  @@index([branchId, attendanceMachineId])
  @@index([personType, personId])
  @@index([attendanceMachineId, machineUserId])
  @@map("attendance_machine_person_maps")
}

model AttendanceEnrollment {
  id                 String                      @id @default(cuid())
  branchId           String
  attendanceMachineId String
  personMapId        String?
  personType         AttendancePersonType
  personId           String
  enrollmentType     AttendanceEnrollmentType
  status             AttendanceEnrollmentStatus @default(PENDING_CAPTURE)
  capturedAt         DateTime?
  confirmedAt        DateTime?
  machineUserId      String?
  qualityScore       Decimal?                   @db.Decimal(5, 2)
  templateVersion    String?
  note               String?
  metadataJson       Json?
