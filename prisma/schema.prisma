  customer       Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  lockerRental   LockerRental? @relation(fields: [lockerRentalId], references: [id], onDelete: SetNull)

  @@unique([branchId, code])
  @@index([branchId, status])
  @@index([deletedAt])
  @@map("deposits")
}

model ProductCategory {
  id          String    @id @default(cuid())
  code        String    @unique
  name        String
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  @@map("product_categories")
}

model Product {
  id               String           @id @default(cuid())
  branchId         String
  categoryId       String?
  code             String
  name             String
  unit             String
  groupName        String?
  purchasePrice    Decimal          @default(0) @db.Decimal(14, 2)
