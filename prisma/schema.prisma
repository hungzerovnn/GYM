  shift        StaffShift           @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  @@id([assignmentId, shiftId])
  @@unique([assignmentId, sequence])
  @@index([shiftId])
  @@map("staff_shift_assignment_shifts")
}

