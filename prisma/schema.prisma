  attendanceMachine  AttendanceMachine          @relation(fields: [attendanceMachineId], references: [id], onDelete: Cascade)
  personMap          AttendanceMachinePersonMap? @relation(fields: [personMapId], references: [id], onDelete: SetNull)
  assets             AttendanceBiometricAsset[]

  @@index([branchId, attendanceMachineId])
  @@index([personType, personId])
  @@index([attendanceMachineId, status])
  @@index([personMapId])
  @@map("attendance_enrollments")
}

model AttendanceBiometricAsset {
  id                 String                         @id @default(cuid())
  branchId           String
  attendanceMachineId String
  enrollmentId       String?
  personType         AttendancePersonType
  personId           String
  assetType          AttendanceBiometricAssetType
  storageProvider    AttendanceStorageProvider
  source             AttendanceBiometricAssetSource @default(UPLOAD)
  storageKey         String
  originalFilename   String?
  mimeType           String?
  fileSize           Int?
  sha256             String?
  createdAt          DateTime                       @default(now())
  updatedAt          DateTime                       @updatedAt
  branch             Branch                         @relation(fields: [branchId], references: [id], onDelete: Restrict)
  attendanceMachine  AttendanceMachine              @relation(fields: [attendanceMachineId], references: [id], onDelete: Cascade)
  enrollment         AttendanceEnrollment?          @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)

  @@index([branchId, attendanceMachineId, assetType])
  @@index([personType, personId])
  @@index([enrollmentId])
  @@index([sha256])
  @@map("attendance_biometric_assets")
}

model StaffAttendanceEvent {
