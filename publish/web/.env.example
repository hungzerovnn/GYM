# Pages proxy project
# Neu deploy bang GitHub Actions, tao GitHub Variables cung ten:
# - CLOUDFLARE_PAGES_PROJECT_NAME
# - FRONTEND_UPSTREAM_URL
# - NEXT_PUBLIC_API_URL
CLOUDFLARE_PAGES_PROJECT_NAME=gymvnchoice

# Frontend Worker that serves the real Next.js app
FRONTEND_UPSTREAM_URL=https://gymvnchoice-web.<your-subdomain>.workers.dev

# API Worker URL used at Next.js build time
NEXT_PUBLIC_API_URL=https://<your-api-worker>.workers.dev/api
